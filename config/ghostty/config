# Ghostty Configuration (used by cmux)

# ===================
# Fonts
# ===================
font-family = MonoLisa
font-family-bold = MonoLisa
font-family-italic = MonoLisa
font-family-bold-italic = MonoLisa
font-size = 13

# Nerd Font icons (fallback for glyphs)
font-codepoint-map = U+E000-U+F8FF=FiraCode Nerd Font
font-codepoint-map = U+F0000-U+FFFFF=FiraCode Nerd Font

# Font rendering
font-thicken = true

# ===================
# Terminal Behavior
# ===================
scrollback-limit = 100000
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false

# Option key as Alt (for terminal keybindings like Alt+C)
macos-option-as-alt = left

# ===================
# Theme
# ===================
theme = Catppuccin Mocha

# ===================
# Split Panes
# ===================
# Dim unfocused splits so the active pane stands out
unfocused-split-opacity = 0.85
# Catppuccin mocha surface0 for dividers
split-divider-color = #313244

# ===================
# Window
# ===================
window-padding-x = 4
window-padding-y = 4

# ===================
# Session / Working Directory
# ===================
# New TAB (⌘T) and new SPLIT inherit the current pane's working dir; a new
# WINDOW (⌘N) opens fresh at $HOME instead. Ghostty has three independent
# inherit toggles — set them explicitly so window vs tab behavior is clear.
# NOTE: Ghostty has no inline comments — keep notes on their own lines, never
# trailing a value (the `#` would be parsed as part of the value).
# ⌘N (new window) → home (~)
window-inherit-working-directory = false
# ⌘T (new tab) → current pwd
tab-inherit-working-directory = true
# new split → current pwd
split-inherit-working-directory = true
# where a non-inheriting window lands
working-directory = home
window-inherit-font-size = true
# Restore window layout on launch (closest analog to cmux session restore)
window-save-state = always
# Confirm quit only if there's an unsaved/running process
quit-after-last-window-closed = false

# ===================
# Keybindings (cmux-style)
# ===================
# Tabs
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+t=undo
# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
# Move between splits
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
# Zoom active split
keybind = cmd+shift+enter=toggle_split_zoom
# Reload config
keybind = cmd+shift+comma=reload_config
# Paste: only handle text; let image clipboard data pass through to the inner
# app (e.g. Claude Code). Workaround for Ghostty discussion #10099.
keybind = performable:cmd+v=paste_from_clipboard
keybind = performable:ctrl+v=paste_from_clipboard

# Newline (without submitting) for Claude Code prompts.
# By default Ghostty sends bare \r for Ctrl+Enter / Shift+Enter, which
# Claude interprets as Enter → submit. Sending a literal \n instead makes
# Claude insert a new line in the prompt.
keybind = ctrl+enter=text:\n
keybind = shift+enter=text:\n

# ===================
# Bell / attention behavior
# ===================
# claude-notify.sh writes BEL to the pane TTY when Claude wants attention
# (Notification hook) or finishes a turn (Stop hook). tmux forwards it
# to Ghostty, which applies these `bell-features`:
#
#   title     - prepends a 🔔 to the alerted tab/window title until the
#               tab is re-focused or you type into it
#   border    - colored border on the alerted pane until you interact
#
# Disabled on purpose:
#   attention - would bounce the Dock icon; we don't want the Dock cue
#   system    - macOS alert beep
#   audio     - custom sound
#
# All alerting is purely in-terminal: the tmux status-left banner
# (bin/tmux-attention.sh) plus these tab/border cues. No Dock bounce,
# no macOS notification.
bell-features = title,border,no-attention,no-system,no-audio
